# TableCheck
TABLECHECK_URL=https://www.tablecheck.com/en/shops/tamafuji-us-kapahulu/reserve
TABLECHECK_SHOP_SLUG=tamafuji-us-kapahulu

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Notification recipients (comma-separated phone numbers)
NOTIFY_PHONES=+18081234567

# Checker settings
CHECK_INTERVAL_SECONDS=120
DEFAULT_PARTY_SIZE=2

TWILIO_RECOVERY=PQA1QCGYAZAPNE1MNFQLANQK

# Email notifications (AWS SES)
SES_FROM_EMAIL=alerts@yourdomain.com
NOTIFY_EMAILS=you@example.com
SMS_ENABLED=false